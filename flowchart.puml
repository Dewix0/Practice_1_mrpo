@startuml

skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 12
skinparam ActivityDiamondFontSize 11
skinparam ActivityFontSize 12

title Блок-схема алгоритма работы приложения\n"ООО Обувь"\n(ГОСТ 19.701-90)

start

:Запуск приложения;

:Отображение окна авторизации;

if (Пользователь выбрал\n"Войти как гость"?) then (да)
  :Установить роль = Гость;
else (нет)
  :Ввод логина и пароля;

  :Отправка данных на сервер\n(POST /api/auth/login);

  if (Логин и пароль верны?) then (да)
    :Получение JWT-токена\nи данных пользователя;
    :Определение роли\n(Клиент / Менеджер / Админ);
  else (нет)
    :Вывод сообщения об ошибке\n"Неверный логин или пароль";
    stop
  endif
endif

:Отображение главного экрана\n(список товаров);

:Загрузка товаров из БД\n(GET /api/products);

:Отображение списка товаров\nс условным оформлением:\n— скидка >15%: фон #2E8B57\n— нет на складе: голубой фон\n— скидка: старая цена зачёркнута;

if (Роль = Менеджер или Админ?) then (да)
  :Отображение тулбара:\nпоиск, фильтр, сортировка;

  :Поиск по текстовым полям\n(в реальном времени);
  :Фильтрация по поставщику\n("Все поставщики" сбрасывает);
  :Сортировка по количеству\n(возрастание / убывание);

  :Обновление списка товаров;
else (нет)
  :Просмотр товаров\nбез фильтрации;
endif

if (Роль = Админ?) then (да)

  ' --- Добавление товара ---
  if (Нажата кнопка\n"Добавить товар"?) then (да)
    :Открытие формы добавления;
    :Заполнение полей: название,\nкатегория, производитель,\nпоставщик, цена, скидка,\nкол-во, ед. изм., фото;
    :Валидация: цена >= 0,\nкол-во >= 0, обяз. поля;

    if (Данные корректны?) then (да)
      :POST /api/products;
      :Загрузка фото (ресайз 300x200)\nPOST /api/products/{id}/image;
      :Обновление списка;
    else (нет)
      :Вывод ошибок валидации;
    endif
  else (нет)
  endif

  ' --- Редактирование товара ---
  if (Нажат элемент\nсписка товаров?) then (да)
    :Открытие формы редактирования\n(данные подгружены из БД,\nID только для чтения);
    :Изменение полей;
    :PUT /api/products/{id};
    :Обновление списка;
  else (нет)
  endif

  ' --- Удаление товара ---
  if (Нажата кнопка\n"Удалить товар"?) then (да)
    :Подтверждение удаления;

    if (Товар в заказе?) then (да)
      :Ошибка 409:\n"Товар присутствует в заказе\nи не может быть удалён";
    else (нет)
      :DELETE /api/products/{id};
      :Обновление списка;
    endif
  else (нет)
  endif

else (нет)
endif

if (Роль = Менеджер или Админ?) then (да)
  :Переход на страницу заказов\n(GET /api/orders);
  :Отображение таблицы:\nартикулы, статус, пункт выдачи,\nдата заказа, дата доставки;

  if (Роль = Админ?) then (да)

    ' --- Добавление заказа ---
    if (Нажата кнопка\n"Добавить заказ"?) then (да)
      :Открытие формы заказа;
      :Заполнение: статус, пункт выдачи,\nдаты, код получения,\nпозиции заказа (товар + кол-во);
      :POST /api/orders;
      :Обновление списка;
    else (нет)
    endif

    ' --- Редактирование заказа ---
    if (Нажат элемент\nсписка заказов?) then (да)
      :Открытие формы с данными заказа;
      :PUT /api/orders/{id};
      :Обновление списка;
    else (нет)
    endif

    ' --- Удаление заказа ---
    if (Нажата кнопка\n"Удалить заказ"?) then (да)
      :Подтверждение удаления;
      :DELETE /api/orders/{id};
      :Обновление списка;
    else (нет)
    endif

  else (нет)
    :Только просмотр заказов;
  endif
else (нет)
endif

if (Нажата кнопка "Выход"?) then (да)
  :POST /api/auth/logout;
  :Возврат на экран авторизации;
else (нет)
  :Продолжение работы;
endif

stop

@enduml
