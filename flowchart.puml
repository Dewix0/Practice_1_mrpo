@startuml Блок-схема алгоритма работы приложения (ГОСТ 19.701-90)

skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 12
skinparam ActivityDiamondFontSize 11
skinparam ActivityFontSize 12

title Блок-схема алгоритма работы приложения\n"ООО Обувь"\n(ГОСТ 19.701-90)

start

:Запуск приложения;

:Отображение окна авторизации;

if (Пользователь\nвыбрал\n"Войти как гость"?) then (да)
  :Установить роль = Гость;
else (нет)
  :Ввод логина и пароля;

  :Отправка данных на сервер\n(POST /api/auth/login);

  if (Логин и пароль\nверны?) then (да)
    :Получение JWT-токена\nи данных пользователя;

    :Определение роли\n(Клиент / Менеджер / Администратор);
  else (нет)
    :Вывод сообщения об ошибке\n"Неверный логин или пароль";

    :Отображение окна авторизации;

    stop
  endif
endif

:Отображение главного экрана\n(список товаров);

:Загрузка данных из БД\n(GET /api/products);

:Отображение списка товаров\nс условным стилем:\n— скидка >15%: фон #2E8B57\n— нет на складе: голубой фон\n— скидка: цена зачёркнута;

if (Роль =\nМенеджер\nили Админ?) then (да)
  :Отображение тулбара:\nпоиск, фильтр по поставщику,\nсортировка по количеству;

  fork
    :Поиск в реальном времени\nпо текстовым полям;
  fork again
    :Фильтрация по поставщику\n("Все поставщики" сбрасывает);
  fork again
    :Сортировка по количеству\n(возрастание / убывание);
  end fork

  :Обновление списка товаров;
else (нет)
  :Просмотр товаров\nбез фильтрации;
endif

if (Роль = Админ?) then (да)
  fork
    :=== Управление товарами ===;

    if (Действие?) then (Добавить)
      :Открытие формы\nдобавления товара;

      :Заполнение полей:\nназвание, категория,\nпроизводитель, поставщик,\nцена, скидка, количество,\nед. измерения, фото;

      :Валидация данных:\nцена ≥ 0, кол-во ≥ 0,\nобязательные поля;

      if (Данные\nкорректны?) then (да)
        :POST /api/products;

        :Загрузка фото\n(ресайз 300×200)\nPOST /api/products/{id}/image;

        :Обновление списка;
      else (нет)
        :Вывод ошибок\nвалидации;
      endif

    else (Редактировать)
      :Открытие формы\nредактирования\n(данные подгружены из БД);

      :Редактирование полей;

      :PUT /api/products/{id};

      :Обновление списка;

    else (Удалить)
      :Подтверждение удаления\n(Modal.confirm);

      if (Товар\nв заказе?) then (да)
        :Ошибка 409:\n"Товар присутствует\nв заказе";
      else (нет)
        :DELETE /api/products/{id};

        :Обновление списка;
      endif
    endif

  fork again
    :=== Управление заказами ===;

    :Переход на страницу заказов\n(GET /api/orders);

    :Отображение таблицы заказов:\nартикулы, статус, пункт выдачи,\nдата заказа, дата доставки;

    if (Действие?) then (Добавить)
      :Открытие формы заказа;

      :Заполнение: статус,\nпункт выдачи, даты,\nкод получения,\nпозиции заказа;

      :POST /api/orders;

      :Обновление списка;

    else (Редактировать)
      :Открытие формы\nс данными заказа;

      :PUT /api/orders/{id};

      :Обновление списка;

    else (Удалить)
      :Подтверждение удаления;

      :DELETE /api/orders/{id};

      :Обновление списка;
    endif
  end fork

else (нет)
  if (Роль = Менеджер?) then (да)
    :Просмотр заказов\n(GET /api/orders)\nтолько чтение;
  else (нет)
    :Только просмотр товаров;
  endif
endif

if (Нажата кнопка\n"Выход"?) then (да)
  :POST /api/auth/logout;

  :Возврат на экран авторизации;

  stop
else (нет)
  :Продолжение работы;
endif

stop

@enduml
